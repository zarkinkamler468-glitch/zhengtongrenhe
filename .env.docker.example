# 复制为 .env 后修改：cp .env.docker.example .env

# MySQL
MYSQL_ROOT_PASSWORD=请改成强密码_root
MYSQL_PASSWORD=请改成强密码_db

# 应用密钥（可用: python3 -c "import secrets; print(secrets.token_urlsafe(48))"）
SECRET_KEY=请改成随机长字符串

# 浏览器访问的完整地址（含 https，不要末尾斜杠）
# 例: https://edu.example.com
PUBLIC_URL=https://你的域名.com

# DeepSeek（可选，不填则 AI 功能受限）
LLM_API_KEY=
