# 生产（宝塔）：CELERY_EAGER=false，DATABASE_URL 指向 127.0.0.1 MySQL
# 本地开发：CELERY_EAGER=true 可简化调试

DATABASE_URL=mysql+aiomysql://edu_policy:密码@127.0.0.1:3306/edu_policy_db?charset=utf8mb4
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_EAGER=false

SECRET_KEY=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

ATTACHMENT_DIR=./data/attachments
DEFAULT_CRAWL_INTERVAL_MINUTES=30

# 邮件推送（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# 微信公众号（可选）
WECHAT_MP_APPID=
WECHAT_MP_SECRET=
WECHAT_MP_TEMPLATE_ID=
