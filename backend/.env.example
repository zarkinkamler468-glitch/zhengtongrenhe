# 本地开发（MySQL 9.6）
DATABASE_URL=mysql+aiomysql://edu_policy:111111@127.0.0.1:3306/edu_policy_db?charset=utf8mb4
CELERY_EAGER=true

# 轻量本地（无需 MySQL）
# DATABASE_URL=sqlite+aiosqlite:///./data/edu_policy.db

# 生产环境（Docker / PostgreSQL）
# DATABASE_URL=postgresql+asyncpg://edu_policy:edu_policy_secret@localhost:5432/edu_policy_db
# CELERY_EAGER=false

REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200
SECRET_KEY=change-me-in-production-use-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# DeepSeek 配置
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=

ATTACHMENT_DIR=./data/attachments
DEFAULT_CRAWL_INTERVAL_MINUTES=30

# 邮件推送（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# 微信公众号模板消息（可选）
WECHAT_MP_APPID=
WECHAT_MP_SECRET=
WECHAT_MP_TEMPLATE_ID=
